<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Framework" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->
    </style>

    <style name="Theme.Framework" parent="Base.Theme.Framework">

        <item name="bottomSheetDialogTheme">@style/BottomSheetStyle</item>

        <item name="android:activityOpenEnterAnimation">@anim/slide_in_right</item>
        <item name="android:activityOpenExitAnimation">@anim/no_animation</item>
        <item name="android:activityCloseEnterAnimation">@anim/no_animation</item>
        <item name="android:activityCloseExitAnimation">@anim/slide_out_right</item>

<!--        <item name="android:activityOpenExitAnimation">@anim/slide_out_left</item>-->
<!--        <item name="android:activityCloseEnterAnimation">@anim/slide_in_left</item>-->

    </style>

    <style name="BottomSheetStyle" parent="Theme.Framework">
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowAnimationStyle">@style/Animation.Design.BottomSheetDialog</item>
<!--        <item name="android:backgroundDimEnabled">true</item>-->
<!--        <item name="android:backgroundDimAmount">0.4</item>-->
    </style>

</resources>